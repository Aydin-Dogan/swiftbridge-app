:{$PORT:8080} {
	root * /app/dist
	file_server

	# Juiste MIME type voor PWA manifest
	header /manifest.webmanifest Content-Type application/manifest+json

	# Service worker mag nooit gecached worden
	header /sw.js Cache-Control "no-cache, no-store, must-revalidate"
	header /sw.js Service-Worker-Allowed /

	# registerSW.js ook niet cachen
	header /registerSW.js Cache-Control "no-cache, no-store, must-revalidate"

	# Assets lang cachen (Vite geeft ze unieke hashes)
	header /assets/* Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback: alle routes → index.html
	try_files {path} /index.html

	# Gzip compressie
	encode gzip
}
